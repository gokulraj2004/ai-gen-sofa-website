# ── Application ──
APP_NAME=sofa website
APP_ENV=development
DEBUG=true
SECRET_KEY=<GENERATE_RANDOM_SECRET_HERE>

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_NAME=sofa_website
DB_USER=<SET_DB_USER>
DB_PASSWORD=<SET_DB_PASSWORD>
DATABASE_URL=postgresql+asyncpg://<SET_DB_USER>:<SET_DB_PASSWORD>@db:5432/sofa_website

# ── Authentication ──
JWT_SECRET_KEY=<GENERATE_RANDOM_JWT_SECRET_HERE>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173